# Copy this file to .env and fill with your own values.

# OpenAI key (for provider=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: default LLM runtime config for main.py
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_MODEL=qwen-plus

# Optional: choose custom env key name in CLI:
# --llm-api-key-env YOUR_KEY_NAME
# YOUR_KEY_NAME=your_api_key_here
