# 复制本文件为 .env 并填入真实值
# Copy this file to .env and fill in your actual values

# API Key（供 openai / openai_compatible provider 使用；ollama / local 模式不需要）
OPENAI_API_KEY=your-api-key-here

# 默认 LLM Provider，可选值：
#   local              — 纯本地占位回答，无需 API key，无需网络
#   ollama             — 本地 Ollama 服务（默认 http://localhost:11434/v1）
#   openai             — OpenAI 官方 API
#   openai_compatible  — 兼容 OpenAI 协议的第三方服务（如阿里云百炼）
LLM_PROVIDER=local
